rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // WARNING: These rules are simplified for development and use a client-side password.
    // In a production app, you should use Firebase Auth and more restrictive rules.
    
    match /cars/{carId} {
      allow read, write: if true;
    }

    match /settings/{docId} {
      allow read, write: if true;
    }

    match /bookings/{bookingId} {
      allow read, write: if true;
    }

    match /customers/{customerId} {
      allow read, write: if true;
    }
  }
}
